# PharmaGenomics Advisor Configuration
# Copy this file to .env and modify as needed

# Ollama Configuration
OLLAMA_HOST=http://localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=medgemma

# Security Configuration
# Set to "true" to allow PHI in inputs (clinical deployment only)
PHI_CLINICAL_USE=false

# Set to "true" to persist genomic data to disk
DATA_PERSISTENCE=false

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Audit Log
AUDIT_LOG_PATH=audit.log

# Max input size (characters)
MAX_INPUT_CHARS=10000
